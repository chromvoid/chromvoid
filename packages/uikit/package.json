{
  "name": "@chromvoid/uikit",
  "version": "0.0.1",
  "description": "Thin Lit UI kit on top of @chromvoid/headless-ui",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "demo": "vite --config ./vite.config.ts --open",
    "lint": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run --config ./vitest.config.ts"
  },
  "dependencies": {
    "@chromvoid/headless-ui": "workspace:*",
    "@reatom/core": "^1000.15.0"
  },
  "peerDependencies": {
    "lit": "^3.0.0"
  },
  "devDependencies": {
    "@unocss/transformer-directives": "^66.6.7",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "unocss": "^66.6.7",
    "vite": "^7.1.0",
    "vitepress": "^1.6.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
