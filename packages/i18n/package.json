{
  "name": "@project/i18n",
  "version": "0.0.1",
  "description": "Small i18n runtime built on Reatom v1000",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "node --import tsx --test --test-force-exit src/**/*.test.ts"
  },
  "keywords": [
    "i18n",
    "reatom",
    "translations"
  ],
  "license": "MIT",
  "dependencies": {
    "@reatom/core": "^1000.15.0"
  }
}
