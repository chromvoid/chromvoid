{
  "name": "@project/i18n",
  "version": "0.0.1",
  "description": "Small i18n runtime built on Reatom v1001",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && node ./scripts/postbuild.mjs",
    "check:exports": "bun run build && node ./scripts/check-package-exports.mjs",
    "check:pack": "bun pm pack --dry-run",
    "lint": "tsc --noEmit -p tsconfig.json",
    "prepack": "bun run build",
    "prepublishOnly": "bun run lint && bun run test && bun run check:exports && bun run check:pack",
    "test": "node --import tsx --test --test-force-exit src/**/*.test.ts"
  },
  "keywords": [
    "i18n",
    "reatom",
    "translations"
  ],
  "license": "MIT",
  "dependencies": {
    "@reatom/core": "^1001.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.11.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
