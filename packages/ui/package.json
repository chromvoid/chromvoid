{
  "name": "@chromvoid/ui",
  "version": "0.0.1",
  "description": "UI components for ChromVoid",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./components": {
      "types": "./src/components/index.ts",
      "import": "./src/components/index.ts",
      "default": "./src/components/index.ts"
    },
    "./components/*": {
      "types": "./src/components/*.ts",
      "import": "./src/components/*.ts",
      "default": "./src/components/*.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "lint": "tsc --noEmit -p tsconfig.test.json",
    "type-check": "tsc --noEmit --incremental false",
    "test": "echo \"No tests defined\"",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run type-check",
    "fix": "oxlint --fix **/*.{ts,tsx}"
  },
  "keywords": [
    "lit",
    "web-components",
    "ui"
  ],
  "author": "ChromVoid Team",
  "license": "AGPL-3.0-only",
  "peerDependencies": {
    "lit": "^3.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
