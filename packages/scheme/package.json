{
  "name": "@chromvoid/scheme",
  "version": "0.1.0",
  "description": "TypeScript types generated from ChromVoid Rust Core",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "fix": "bun run lint:fix && bun run format",
    "lint:fix": "oxlint --fix src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "generate": "cd ../.. && bun run types:generate",
    "prepublish": "bun run generate && bun run build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist",
    "src"
  ],
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/chromvoid/chromvoid"
  }
}
