{
  "name": "chromvoid-monorepo",
  "private": true,
  "version": "0.0.1",
  "description": "",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "sync": "node scripts/sync-public.mjs /Users/kaifat/Documents/chromvoid-public",
    "types:generate": "./scripts/generate-ts-bindings.sh",
    "lint": "bun ./scripts/check-color-system.mjs && bun ./scripts/check-frontend-tech-debt.mjs && bun ./scripts/check-native-first-ui.mjs && bunx oxlint **/*.{js,ts,tsx,json}",
    "lint:fix": "bunx oxlint --fix **/*.{js,ts,tsx,json,md}",
    "format": "prettier --write **/*.{js,ts,tsx,json,md}",
    "format:check": "prettier --check **/*.{js,ts,tsx,json,md}",
    "prettify": "prettier --write **/*.json",
    "fix": "bun run lint:fix && bun run format",
    "check:no-webawesome": "node ./scripts/check-no-webawesome.mjs",
    "check:webview-motion-loops": "node ./scripts/check-webview-motion-loops.mjs",
    "check:ui-unification": "node ./scripts/check-ui-unification.mjs packages/passmanager/src",
    "check:frontend-tech-debt": "bun ./scripts/check-frontend-tech-debt.mjs",
    "check:native-first-ui": "bun ./scripts/check-native-first-ui.mjs",
    "check:tauri-stability": "bash scripts/check-tauri-stability-gates.sh",
    "docs:check:backend-adr": "bash scripts/security/check-backend-adr-hygiene.sh",
    "test": "bun run test:rust && bun run test:ts && bun run test:e2e",
    "check:color-system": "bun ./scripts/check-color-system.mjs",
    "test:ts": "bun run check:no-webawesome && bun run check:color-system && bun ./scripts/check-color-system.test.mjs && bun run --workspaces --if-present test",
    "test:e2e": "bun run --cwd apps/webview test:e2e",
    "rust:build": "./scripts/build.sh",
    "rust:test": "cargo test --workspace",
    "rust:test:core": "cargo test -p chromvoid-core",
    "rust:test:desktop": "cd apps/chromvoid/src-tauri && cargo test --features desktop",
    "rust:test:desktop:perf-gates": "cd apps/chromvoid/src-tauri && cargo test --features desktop commands::vault::rpc::dispatch::tests::ssh_agent_reconcile_triggers_for_entry_mutations && cargo test --features desktop commands::catalog::download::tests::core_backed_derivative && cargo test --features desktop commands::catalog::download::tests::image_metadata_miss_persists_and_second_call_uses_cache",
    "rust:test:desktop:fuse": "cd apps/chromvoid/src-tauri && cargo test --features desktop fuse_rw_roundtrip_mount_smoke -- --ignored --nocapture",
    "rust:test:desktop:fuse:required": "CHROMVOID_TEST_INMEMORY_KEYSTORE=1 CHROMVOID_REQUIRE_FUSE=1 cargo test --manifest-path apps/chromvoid/src-tauri/Cargo.toml --features desktop --test volume_fuse_rw -- --nocapture --test-threads=1 && CHROMVOID_TEST_INMEMORY_KEYSTORE=1 CHROMVOID_REQUIRE_FUSE=1 cargo test --manifest-path apps/chromvoid/src-tauri/Cargo.toml --features desktop --test volume_fuse_matrix -- --nocapture --test-threads=1 && CHROMVOID_TEST_INMEMORY_KEYSTORE=1 CHROMVOID_REQUIRE_FUSE=1 cargo test --manifest-path apps/chromvoid/src-tauri/Cargo.toml --features desktop --test volume_fuse_root_shard -- --nocapture --test-threads=1 && CHROMVOID_TEST_INMEMORY_KEYSTORE=1 CHROMVOID_REQUIRE_FUSE=1 cargo test --manifest-path apps/chromvoid/src-tauri/Cargo.toml --features desktop --test volume_cross_backend -- --nocapture --test-threads=1",
    "rust:integration": "cd crates/core && cargo test --test vault_workflow",
    "rust:e2e": "cargo test --manifest-path apps/chromvoid/src-tauri/Cargo.toml --features desktop --test e2e_user_scenarios -- --nocapture --test-threads=1",
    "test:rust": "bun run rust:test && bun run rust:test:desktop",
    "test:macos": "bun run rust:test:desktop:fuse:required",
    "test:volume:local": "bash scripts/volume/verify-macos-fuse-local.sh ${TASK_N:-1} && bash scripts/volume/volume-local-gates-summary.sh ${TASK_N:-1}",
    "preflight:ios": "node ./scripts/mobile/preflight-ios-check.mjs",
    "preflight:macos:packet-tunnel": "node ./scripts/mobile/preflight-macos-packet-tunnel-check.mjs",
    "preflight:android": "node ./scripts/mobile/preflight-android-check.mjs",
    "preflight:android:ui": "node ./scripts/mobile/preflight-android-ui-check.mjs",
    "preflight:android:release": "node ./scripts/mobile/preflight-android-release-check.mjs",
    "perf:gates": "bun run perf:gates:fixture && bun run perf:gates:webview && bun run perf:gates:rust",
    "perf:gates:fixture": "node ./scripts/mobile/parse-media-catalog-perf-log.mjs --input ./scripts/mobile/fixtures/media-catalog-perf-logcat.sample.txt --scenario fixture --build-type debug --output-json /tmp/chromvoid-perf-gates-fixture.json",
    "perf:gates:webview": "bun run --cwd apps/webview test:perf:gates",
    "perf:gates:rust": "bun run rust:test:core && bash scripts/perf/run-core-perf-gates.sh && bun run rust:test:desktop:perf-gates",
    "perf:gates:android": "node ./scripts/mobile/capture-media-catalog-perf.mjs",
    "test:ios:check": "bun run preflight:ios && cargo check --manifest-path apps/chromvoid/src-tauri/Cargo.toml --target aarch64-apple-ios-sim --no-default-features --features ios",
    "test:ios:integration": "node ./scripts/mobile/test-ios-integration.mjs full",
    "test:ios:integration:webrtc": "node ./scripts/mobile/test-ios-integration.mjs webrtc",
    "test:ios:integration:wss-fallback": "node ./scripts/mobile/test-ios-integration.mjs wss-fallback",
    "test:android:check": "bun run test:android:warnings",
    "test:android:providers": "node ./scripts/mobile/test-android-providers.mjs full",
    "test:android:providers:physical": "node ./scripts/mobile/test-android-providers.mjs physical",
    "test:android:providers:api28": "node ./scripts/mobile/test-android-providers.mjs api28",
    "test:android:providers:api33": "node ./scripts/mobile/test-android-providers.mjs api33",
    "test:android:providers:api34": "node ./scripts/mobile/test-android-providers.mjs api34",
    "test:android:ui": "node ./scripts/mobile/test-android-ui.mjs emulator",
    "test:android:ui:smoke": "node ./scripts/mobile/test-android-ui.mjs emulator",
    "test:android:ui:physical": "node ./scripts/mobile/test-android-ui.mjs physical",
    "test:android:ui:doctor": "node ./scripts/mobile/preflight-android-ui-check.mjs",
    "test:android:catalog-smoke": "bash scripts/mobile/android-catalog-smoke.sh",
    "test:android:warnings": "node ./scripts/mobile/check-android-rust-warnings.mjs",
    "test:build-warnings": "bun run --cwd apps/webview build:check-warnings",
    "test:warnings": "bun run test:android:warnings && bun run test:build-warnings",
    "test:mobile": "bun run test:ios:check && bun run test:android:check",
    "test:mobile:full": "bun run test:mobile && bun run test:ios:integration",
    "ios:dev:device": "bun run --cwd apps/chromvoid ios:dev:device",
    "ios:deploy:device": "bun run --cwd apps/chromvoid ios:deploy:device",
    "ios:deploy:device:launch": "bun run --cwd apps/chromvoid ios:deploy:device:launch",
    "android:build:release:apk": "bun run preflight:android:release && bun run --cwd apps/chromvoid android:build:release:apk",
    "android:build:release:aab": "bun run preflight:android:release && bun run --cwd apps/chromvoid android:build:release:aab",
    "android:play:check-access": "node ./scripts/mobile/release-google-play-android.mjs --check-access",
    "android:play:release:internal": "bun run android:build:release:aab && node ./scripts/mobile/release-google-play-android.mjs --track internal --confirm-upload",
    "marketing:play:screenshots": "node business/marketing/play/prepare-google-play-screenshots.mjs",
    "marketing:play:tablet-screenshots": "node business/marketing/play/capture-tablet-screenshots.mjs",
    "android:adb-wifi": "bun run --cwd apps/chromvoid android:adb-wifi --",
    "android:install:release:apk": "bun run --cwd apps/chromvoid android:install:release:apk",
    "android:deploy:release:apk": "bun run preflight:android:release && bun run --cwd apps/chromvoid android:deploy:release:apk",
    "android:deploy:release:apk:wifi": "bun run preflight:android:release && bun run --cwd apps/chromvoid android:deploy:release:apk:wifi",
    "dashboard:dev": "bun run --cwd apps/webview dev",
    "dashboard:build": "bun run --cwd apps/webview build",
    "desktop:tauri:dev": "bun run --cwd apps/chromvoid dev:run",
    "desktop:tauri:build": "bun run --cwd apps/chromvoid build",
    "desktop:dev": "bun run desktop:tauri:dev",
    "desktop:build": "bun run dashboard:build && bun run desktop:tauri:build",
    "landing:dev": "./scripts/landing-dev.sh",
    "landing:build": "bun run --cwd backend/landings build",
    "backend:dev": "./scripts/backend-dev.sh",
    "admin:dev": "bash scripts/admin-ui-local-dev.sh",
    "admin:dev:ui": "bun run --cwd backend/admin-ui dev",
    "admin:dev:prod": "bash scripts/admin-ui-dev-prod.sh",
    "admin:dev:tailscale": "bun run --cwd backend/admin-ui dev:prod",
    "admin:build": "bun run --cwd backend/admin-ui build",
    "backend:docker:build": "docker build -f backend/Dockerfile -t chromvoid-backend .",
    "backend:infra": "docker compose -f backend/docker-compose.yml up postgres redis -d",
    "backend:infra:down": "docker compose -f backend/docker-compose.yml down",
    "infra:check:timeweb": "bash scripts/infra/check-timeweb-target-prod.sh",
    "infra:check:timeweb:stacks": "bash scripts/infra/timeweb-prod-stacks.sh check",
    "infra:relay:smoke": "node ./scripts/infra/relay-smoke.mjs",
    "infra:prod:timeweb": "bash scripts/infra/timeweb-prod.sh",
    "infra:prod:timeweb:stacks": "bash scripts/infra/timeweb-prod-stacks.sh",
    "infra:prod:timeweb:app": "bash scripts/infra/timeweb-app-rollout.sh",
    "infra:prod:timeweb:app:status": "bash scripts/infra/timeweb-app-rollout.sh status",
    "infra:prod:timeweb:app:deploy": "bash scripts/infra/timeweb-app-rollout.sh deploy",
    "infra:prod:timeweb:app:rollback": "bash scripts/infra/timeweb-app-rollout.sh rollback",
    "infra:prod:timeweb:rollout": "bash scripts/infra/timeweb-rollout.sh",
    "infra:test:timeweb:app-rollout": "bash scripts/infra/timeweb-app-rollout.test.sh",
    "deploy:timeweb": "bash scripts/infra/timeweb-deploy.sh"
  },
  "keywords": [],
  "author": "",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "devDependencies": {
    "@prettier/plugin-oxc": "^0.1.3",
    "@tauri-apps/cli": "2.10.1",
    "@trivago/prettier-plugin-sort-imports": "4.2.0",
    "@types/dom-view-transitions": "1.0.4",
    "@types/node": "^24.11.0",
    "@types/uuid": "^9.0.8",
    "appium": "^3.2.2",
    "browserslist": "^4.28.1",
    "lightningcss": "^1.31.1",
    "lit": "^3.3.2",
    "otpauth": "9.1.4",
    "oxlint": "^1.51.0",
    "prettier": "^3.8.1",
    "sharp": "0.34.5",
    "ts-lit-plugin": "1.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "uuid": "^9.0.1",
    "webdriverio": "^9.26.1"
  }
}
