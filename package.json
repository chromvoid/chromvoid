{
  "name": "chromvoid-monorepo",
  "version": "0.0.1",
  "description": "",
  "scripts": {
    "sync": "node scripts/sync-public.mjs /Users/kaifat/Documents/chromvoid-public",
    "types:generate": "./scripts/generate-ts-bindings.sh",
    "lint": "oxlint **/*.{js,ts,tsx,json}",
    "lint:fix": "oxlint --fix **/*.{js,ts,tsx,json,md}",
    "format": "prettier --write **/*.{js,ts,tsx,json,md}",
    "format:check": "prettier --check **/*.{js,ts,tsx,json,md}",
    "prettify": "prettier --write **/*.json",
    "fix": "npm run lint:fix && npm run format",
    "check:no-webawesome": "node ./scripts/check-no-webawesome.mjs",
    "check:ui-unification": "node ./scripts/check-ui-unification.mjs packages/passmanager/src",
    "docs:check:backend-adr": "bash scripts/security/check-backend-adr-hygiene.sh",
    "test": "run-s test:rust test:ts test:e2e",
    "test:ts": "npm run check:no-webawesome && npm run test --workspaces --if-present",
    "test:e2e": "npm run test:e2e -w apps/webview",
    "rust:build": "./scripts/build.sh",
    "rust:test": "cargo test --workspace",
    "rust:test:core": "cargo test -p chromvoid-core",
    "rust:test:desktop": "cd apps/chromvoid/src-tauri && cargo test",
    "rust:test:desktop:fuse": "cd apps/chromvoid/src-tauri && cargo test fuse_rw_roundtrip_mount_smoke -- --ignored --nocapture",
    "rust:test:desktop:fuse:required": "CHROMVOID_TEST_INMEMORY_KEYSTORE=1 CHROMVOID_REQUIRE_FUSE=1 cargo test --manifest-path apps/chromvoid/src-tauri/Cargo.toml --test volume_fuse_rw -- --nocapture --test-threads=1 && CHROMVOID_TEST_INMEMORY_KEYSTORE=1 CHROMVOID_REQUIRE_FUSE=1 cargo test --manifest-path apps/chromvoid/src-tauri/Cargo.toml --test volume_fuse_matrix -- --nocapture --test-threads=1 && CHROMVOID_TEST_INMEMORY_KEYSTORE=1 CHROMVOID_REQUIRE_FUSE=1 cargo test --manifest-path apps/chromvoid/src-tauri/Cargo.toml --test volume_fuse_root_shard -- --nocapture --test-threads=1 && CHROMVOID_TEST_INMEMORY_KEYSTORE=1 CHROMVOID_REQUIRE_FUSE=1 cargo test --manifest-path apps/chromvoid/src-tauri/Cargo.toml --test volume_cross_backend -- --nocapture --test-threads=1",
    "rust:integration": "cd crates/core && cargo test --test vault_workflow",
    "rust:e2e": "cargo test --manifest-path apps/chromvoid/src-tauri/Cargo.toml --test e2e_user_scenarios -- --nocapture --test-threads=1",
    "test:rust": "run-s rust:test rust:test:desktop",
    "test:macos": "npm run rust:test:desktop:fuse:required",
    "test:volume:local": "bash scripts/volume/verify-macos-fuse-local.sh ${TASK_N:-1} && bash scripts/volume/volume-local-gates-summary.sh ${TASK_N:-1}",
    "preflight:ios": "node ./scripts/mobile/preflight-ios-check.mjs",
    "preflight:macos:packet-tunnel": "node ./scripts/mobile/preflight-macos-packet-tunnel-check.mjs",
    "preflight:android": "node ./scripts/mobile/preflight-android-check.mjs",
    "preflight:android:ui": "node ./scripts/mobile/preflight-android-ui-check.mjs",
    "preflight:android:release": "node ./scripts/mobile/preflight-android-release-check.mjs",
    "test:ios:check": "npm run preflight:ios && cargo check --manifest-path apps/chromvoid/src-tauri/Cargo.toml --target aarch64-apple-ios-sim --no-default-features --features ios",
    "test:ios:integration": "node ./scripts/mobile/test-ios-integration.mjs full",
    "test:ios:integration:webrtc": "node ./scripts/mobile/test-ios-integration.mjs webrtc",
    "test:ios:integration:wss-fallback": "node ./scripts/mobile/test-ios-integration.mjs wss-fallback",
    "test:android:check": "npm run preflight:android && cargo check --manifest-path apps/chromvoid/src-tauri/Cargo.toml --target aarch64-linux-android --no-default-features --features android",
    "test:android:providers": "node ./scripts/mobile/test-android-providers.mjs full",
    "test:android:providers:physical": "node ./scripts/mobile/test-android-providers.mjs physical",
    "test:android:providers:api28": "node ./scripts/mobile/test-android-providers.mjs api28",
    "test:android:providers:api33": "node ./scripts/mobile/test-android-providers.mjs api33",
    "test:android:providers:api34": "node ./scripts/mobile/test-android-providers.mjs api34",
    "test:android:ui": "node ./scripts/mobile/test-android-ui.mjs emulator",
    "test:android:ui:smoke": "node ./scripts/mobile/test-android-ui.mjs emulator",
    "test:android:ui:physical": "node ./scripts/mobile/test-android-ui.mjs physical",
    "test:android:ui:doctor": "node ./scripts/mobile/preflight-android-ui-check.mjs",
    "test:mobile": "run-s test:ios:check test:android:check",
    "test:mobile:full": "run-s test:mobile test:ios:integration",
    "android:build:release:apk": "npm run preflight:android:release && npm run android:build:release:apk -w apps/chromvoid",
    "android:deploy:release:apk": "npm run preflight:android:release && npm run android:deploy:release:apk -w apps/chromvoid",
    "dashboard:dev": "npm run dev -w apps/webview",
    "dashboard:build": "npm run build -w apps/webview",
    "desktop:tauri:dev": "npm run dev:run -w apps/chromvoid",
    "desktop:tauri:build": "npm run build -w apps/chromvoid",
    "desktop:dev": "npm run desktop:tauri:dev",
    "desktop:build": "npm run dashboard:build && npm run desktop:tauri:build",
    "landing:dev": "./scripts/landing-dev.sh",
    "landing:build": "npm run build --prefix backend/landings",
    "backend:dev": "./scripts/backend-dev.sh",
    "backend:docker:build": "docker build -t chromvoid-backend backend",
    "backend:infra": "docker compose -f backend/docker-compose.yml up postgres redis -d",
    "backend:infra:down": "docker compose -f backend/docker-compose.yml down",
    "infra:check:timeweb": "bash scripts/infra/check-timeweb-target-prod.sh",
    "infra:check:timeweb:stacks": "bash scripts/infra/timeweb-prod-stacks.sh check",
    "infra:relay:smoke": "node ./scripts/infra/relay-smoke.mjs",
    "infra:prod:timeweb": "bash scripts/infra/timeweb-prod.sh",
    "infra:prod:timeweb:stacks": "bash scripts/infra/timeweb-prod-stacks.sh",
    "infra:prod:timeweb:app": "bash scripts/infra/timeweb-app-rollout.sh",
    "infra:prod:timeweb:app:status": "bash scripts/infra/timeweb-app-rollout.sh status",
    "infra:prod:timeweb:app:deploy": "bash scripts/infra/timeweb-app-rollout.sh deploy",
    "infra:prod:timeweb:app:rollback": "bash scripts/infra/timeweb-app-rollout.sh rollback",
    "infra:prod:timeweb:rollout": "bash scripts/infra/timeweb-rollout.sh",
    "infra:test:timeweb:app-rollout": "bash scripts/infra/timeweb-app-rollout.test.sh",
    "deploy:timeweb": "bash scripts/infra/timeweb-deploy.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "devDependencies": {
    "@prettier/plugin-oxc": "^0.1.3",
