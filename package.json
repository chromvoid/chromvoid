    "@statx/element": "1.15.2",
    "@statx/i18n": "1.15.2",
    "@statx/lit": "1.15.5",
    "@statx/machine": "1.15.2",
    "@statx/persist": "1.15.2",
    "@statx/router": "1.15.2",
    "@statx/utils": "1.13.0",
    "@tauri-apps/cli": "^2.10.1",
    "@trivago/prettier-plugin-sort-imports": "4.2.0",
    "@types/dom-view-transitions": "1.0.4",
    "@types/node": "^24.11.0",
    "@types/uuid": "^9.0.8",
    "appium": "^3.2.2",
    "browserslist": "^4.28.1",
    "crc-32": "^1.2.2",
    "generate-password-ts": "1.6.5",
    "hash-wasm": "^4.12.0",
    "lightningcss": "^1.31.1",
    "lit": "^3.3.2",
    "npm-run-all": "4.1.5",
    "otpauth": "9.1.4",
    "oxlint": "^1.51.0",
    "prettier": "^3.8.1",
    "sweetalert2": "11.9.0",
    "ts-lit-plugin": "1.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "uuid": "^9.0.1",
    "webdriverio": "^9.26.1"
  }
}
