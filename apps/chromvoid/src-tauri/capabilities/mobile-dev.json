{
  "identifier": "mobile-dev",
  "description": "Main ChromVoid mobile window IPC permissions for development - allows localhost/LAN dev server.",
  "platforms": ["iOS", "android"],
  "remote": {
    "urls": [
      "http://localhost:4400/*",
      "http://127.0.0.1:4400/*",
      "http://*:4400/*",
      "http://localhost:4410/*",
      "http://127.0.0.1:4410/*",
      "http://*:4410/*"
    ]
  },
  "windows": ["main"],
  "permissions": [
    "core:default",
    "mobile",
    "dialog:default",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text"
  ]
}
