{
  "name": "ChromVoid PasswordManager",
  "description": "Fill passwords and OTPs from ChromVoid UNO",
  "version": "1.0",
  "manifest_version": 3,
  "key": "f4a5b3c2d1e6a7b8c9d0e1f2a3b4c5d6",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_popup": "./popup.html"
  },
  "permissions": ["tabs"],

  "host_permissions": [
    "http://chromvoid.local/*",
    "https://chromvoid.local/*",
    "http://localhost/*",
    "https://localhost/*",
    "http://127.0.0.1/*",
    "https://127.0.0.1/*",
    "http://[::1]/*",
    "https://[::1]/*"
  ],
  "content_scripts": [
    {
      "js": ["dist/injectable.js"],
      "matches": ["*://*/*"],
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "dist/service-worker.js"
  }
}
