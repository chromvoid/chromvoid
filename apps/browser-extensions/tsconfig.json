{
  "extends": "../../tsconfig.json",
  "include": ["./src/**/*"],
  "exclude": ["node_modules/*", "/scripts/*"],

  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "../..",
    "types": ["node", "chrome"],
    "paths": {
      "@chromvoid/scheme": ["../../packages/scheme/src/index.ts"],
      "@chromvoid/scheme/*": ["../../packages/scheme/src/*"],
      "@project/i18n": ["../../packages/i18n/src/index.ts"],
      "@project/i18n/*": ["../../packages/i18n/src/*"],
      "root/*": ["./src/*", "../webview/src/*"]
    }
  }
}
