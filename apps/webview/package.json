{
  "name": "dashboard",
  "version": "1.0.0",
  "description": "ChromVoid device",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "build": "npm run build -w @project/passmanager && vite build",
    "build:check-warnings": "node ./scripts/check-build-warnings.mjs",
    "dev": "vite",
    "vendor:fonts": "tsx ./scripts/vendor-fonts.ts",
    "lint": "tsc --project . --noEmit",
    "fix": "oxlint --fix \"**/*.{ts,tsx}\"",
    "test": "vitest run --config ./vitest.unit.config.ts",
    "test:perf:gates": "vitest run --config ./vitest.unit.config.ts tests/unit/media-inspection-flow.test.ts tests/unit/image-display-scheduler.test.ts tests/unit/image-derivative-prewarm.test.ts tests/unit/catalog-sync.test.ts tests/unit/catalog.notifications.test.ts",
    "test:unit": "vitest --config ./vitest.unit.config.ts",
    "test:unit:watch": "vitest --config ./vitest.unit.config.ts --watch",
    "test:e2e": "DASHBOARD_E2E=1 vitest --config ./vitest.config.ts",
    "test:e2e:headed": "DASHBOARD_E2E=1 HEADED=1 vitest --config ./vitest.config.ts",
    "test:e2e:visual": "DASHBOARD_E2E=1 vitest --config ./vitest.config.ts tests/e2e/visual",
    "test:e2e:visual:update": "DASHBOARD_E2E=1 UPDATE_VISUAL_SNAPSHOTS=1 vitest --config ./vitest.config.ts tests/e2e/visual",
    "perf:passwords-root": "node ./scripts/perf-passmanager-root.mjs"
  },
  "keywords": [],
  "author": "Kaifat",
  "dependencies": {
    "@chromvoid/password-import": "workspace:*",
    "@chromvoid/ui": "workspace:*",
    "@chromvoid/uikit": "workspace:*",
    "@lit-labs/virtualizer": "^2.1.1",
    "@project/i18n": "workspace:*",
    "@project/passmanager": "workspace:*",
    "@project/utils": "workspace:*",
    "@reatom/core": "^1000.15.0",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-dialog": "2.6.0",
    "dompurify": "^3.4.1",
    "markdown-it": "^14.1.1",
    "prettier": "^3.8.1"
  },
  "devDependencies": {
    "@blazediff/core": "1.9.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.9.0",
    "@vitest/browser": "^4.1.1",
    "jsdom": "^26.1.0",
    "playwright": "^1.54.2",
    "pngjs": "7.0.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  }
}
