{
  "include": ["./src/**/*"],
  "exclude": ["node_modules/*", "/scripts/*"],

  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["dom", "es2022", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "types": ["node"],
    "paths": {
      "@project/i18n": ["../../packages/i18n/src/index.ts"],
      "@project/i18n/*": ["../../packages/i18n/src/*"],
      "@project/passmanager/i18n": ["../../packages/passmanager/src/i18n/index.ts"],
      "@project/passmanager/i18n/format": ["../../packages/passmanager/src/i18n/format.ts"],
      "@project/passmanager/core": ["../../packages/passmanager/src/core.ts"],
      "@project/passmanager/types": ["../../packages/passmanager/src/types.ts"],
      "@project/passmanager/select": ["../../packages/passmanager/src/service/select.ts"],
      "@project/passmanager/sorting": ["../../packages/passmanager/src/service/sorting.ts"],
      "@project/passmanager/sort-storage": ["../../packages/passmanager/src/service/sort-storage.ts"],
      "@project/passmanager/security-audit": ["../../packages/passmanager/src/security-audit.ts"],
      "@project/passmanager/theme": ["../../packages/passmanager/src/service/theme.ts"],
      "@project/passmanager/timer": ["../../packages/passmanager/src/timer.ts"],
      "@chromvoid/uikit/dialog": ["../../packages/uikit/dist/dialog/index.d.ts"],
      "@chromvoid/uikit/dialog/*": ["../../packages/uikit/dist/dialog/*.d.ts"],
      "@chromvoid/uikit/reatom-lit": ["../../packages/uikit/dist/reatom-lit/index.d.ts"],
      "@chromvoid/scheme": ["../../packages/scheme/src/index.ts"],
      "@chromvoid/scheme/*": ["../../packages/scheme/src/*"],
      "@chromvoid/ui": ["../../packages/ui/src/index.ts"],
      "@chromvoid/ui/*": ["../../packages/ui/src/*"],
      "root/*": ["./src/*"]
    },

    // Type checking
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noPropertyAccessFromIndexSignature": true,

    // Module options
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "allowUnreachableCode": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    // Lit plugin
    "plugins": [
      {
        "name": "ts-lit-plugin",
        "strict": true,
        "globalTags": [
          "cv-accordion",
          "cv-accordion-item",
          "cv-alert",
          "cv-alert-dialog",
          "cv-badge",
          "cv-breadcrumb",
          "cv-breadcrumb-item",
          "cv-button",
          "cv-card",
          "cv-carousel",
          "cv-carousel-slide",
          "cv-checkbox",
          "cv-combobox",
          "cv-combobox-group",
          "cv-combobox-option",
          "cv-command-item",
          "cv-command-palette",
          "cv-context-menu",
          "cv-copy-button",
          "cv-date-picker",
          "cv-dialog",
          "cv-disclosure",
          "cv-feed",
          "cv-feed-article",
          "cv-grid",
          "cv-grid-cell",
          "cv-grid-column",
          "cv-grid-row",
          "cv-input",
          "cv-landmark",
          "cv-link",
          "cv-listbox",
          "cv-listbox-group",
          "cv-menu",
          "cv-menu-button",
          "cv-menu-group",
          "cv-menu-item",
          "cv-meter",
          "cv-number",
          "cv-option",
          "cv-popover",
          "cv-progress",
          "cv-progress-ring",
          "cv-radio",
          "cv-radio-group",
          "cv-select",
          "cv-select-group",
          "cv-select-option",
          "cv-slider",
          "cv-slider-multi-thumb",
          "cv-spinbutton",
          "cv-switch",
          "cv-tab",
          "cv-tab-panel",
          "cv-table",
          "cv-table-cell",
          "cv-table-column",
          "cv-table-row",
          "cv-tabs",
          "cv-textarea",
          "cv-toast",
          "cv-toast-region",
          "cv-toolbar",
          "cv-toolbar-item",
          "cv-toolbar-separator",
          "cv-tooltip",
          "cv-treegrid",
          "cv-treegrid-cell",
          "cv-treegrid-column",
          "cv-treegrid-row",
          "cv-treeitem",
          "cv-treeview",
          "cv-window-splitter"
        ]
      }
    ]
  }
}
