# RAG-specific exclusions to keep retrieval focused on real product code/docs

# Tooling state / agent artifacts
.claude/**
.cursor/**
.opencode/**
.sisyphus/**
.planning/**

# Local environment/editor artifacts
.devcontainer/**
.openclaw/**

# Build/cache/vendor
node_modules/**
dist/**
build/**
target/**
coverage/**
.parcel-cache/**

# Product-irrelevant content that pollutes code retrieval
backend/landings/**
business/landing/**
business/marketing/**
specs/attachments/**
apps/chromvoid/src-tauri/permissions/autogenerated/**
apps/chromvoid/src-tauri/gen/schemas/**
apps/webview/src/i18n/**
packages/passmanager/src/i18n/**
apps/webview/src/assets/icons/**
apps/browser-extensions/assets/icons/**
packages/ui/src/icons/**
apps/webview/.mock-data/**
